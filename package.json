{
  "name": "zustand-devtools-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:types": "tsc -p bridge/tsconfig.typetest.json --noEmit && tsc -p bridge/tsconfig.typetest4.json --noEmit",
    "build:bridge": "tsc -p bridge/tsconfig.json",
    "check": "npm run build:bridge && npm run test:types && npm run test && npm run pack:bridge",
    "pack:bridge": "npm pack --dry-run --workspace zustand-devtools-bridge"
  },
  "devDependencies": {
    "jsdom": "^24.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zustand4": "npm:zustand@^4.5.7",
    "zustand5": "npm:zustand@^5.0.0"
  },
  "workspaces": [
    "bridge"
  ]
}