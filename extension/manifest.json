{
  "manifest_version": 3,
  "name": "Zustand DevTools",
  "version": "1.0.0",
  "description": "Live component state inspector for Zustand, plus an optional action log and time-travel debugging.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api.lemonsqueezy.com/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-script.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
